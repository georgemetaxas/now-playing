<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.metaxas.nowplaying-lights</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/georgemetaxas/Claude/yt-now-playing/lights/.venv/bin/python</string>
    <string>/Users/georgemetaxas/Claude/yt-now-playing/lights/tapo_sync.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/georgemetaxas/Claude/yt-now-playing/lights</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <!-- if it crashes (or config isn't ready yet), wait 30s before retrying -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/Users/georgemetaxas/Claude/yt-now-playing/lights/tapo_sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/georgemetaxas/Claude/yt-now-playing/lights/tapo_sync.log</string>
</dict>
</plist>
